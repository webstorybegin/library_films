{
  "name": "library-films",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "homepage": "./",
  "author": "Dmytro",
  "description": "Netflix-style movie library app",
  "dependencies": {
    "@testing-library/react": "^12.1.2",
    "@testing-library/user-event": "^13.5.0",
    "eslint-plugin": "^1.0.1",
    "path-browserify": "^1.0.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router-dom": "^6.2.1",
    "react-scripts": "5.0.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "electron": "electron .",
    "dev": "concurrently \"npm run start\" \"npm run electron\"",
    "build:react": "react-scripts build",
    "build:electron": "electron-builder",
    "build": "npm run build:react && npm run build:electron",
    "build:portable": "npm run build:react && electron-builder --win portable",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "deploy": "gh-pages -d build",
    "predeploy": "npm run build:react"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.dmytro.library-films",
    "productName": "LibraryFilms",
    "extends": null,
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "electron/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/resources/icons/app_icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@emotion/react": "^11.7.1",
    "@emotion/styled": "^11.6.0",
    "@material-ui/core": "^4.12.3",
    "@mui/material": "^5.3.0",
    "@types/electron": "^1.6.10",
    "@types/react": "^17.0.38",
    "classnames": "^2.5.1",
    "concurrently": "^8.2.2",
    "electron": "^36.3.1",
    "electron-builder": "^24.13.3",
    "gh-pages": "^4.0.0",
    "png-to-ico": "^3.0.1",
    "sass": "^1.75.0",
    "sharp": "^0.34.5",
    "typescript": "^4.9.5"
  }
}
